{
  "name": "fairfield-airport-cars",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "test": "npm run test:integration && npm run test:unit && npm run test:e2e",
    "test:unit": "NODE_OPTIONS=\"--max-old-space-size=8192\" vitest run tests/unit/page-loading-rtl.test.tsx tests/unit/business-flows.test.tsx tests/unit/msw-test.spec.ts --coverage",
    "test:integration": "vitest run tests/integration --coverage",
    "test:e2e": "playwright test --config config/playwright.config.ts tests/e2e/critical-flows/streamlined-user-flows.spec.ts",
    "firebase:emulators": "firebase emulators:start",
    "firebase:emulators:seed": "node scripts/seed-cms-to-emulators.js",
    "deploy": "npm run build && vercel --prod",
    "deploy:preview": "npm run build && vercel"
  },
  "dependencies": {
    "@fullcalendar/core": "^6.1.18",
    "@fullcalendar/daygrid": "^6.1.10",
    "@fullcalendar/react": "^6.1.10",
    "@googlemaps/google-maps-services-js": "^3.4.1",
    "@hookform/resolvers": "^5.1.1",
    "@types/styled-components": "^5.1.34",
    "@vercel/analytics": "^1.5.0",
    "autoprefixer": "^10.4.21",
    "dompurify": "^3.2.6",
    "dotenv": "^17.2.1",
    "firebase": "^11.10.0",
    "firebase-admin": "^13.4.0",
    "ics": "^2.41.0",
    "lucide-react": "^0.525.0",
    "next": "15.3.4",
    "nodemailer": "^7.0.5",
    "octokit": "^5.0.3",
    "openai": "^5.9.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.59.0",
    "square": "^43.0.0",
    "styled-components": "^6.1.19",
    "twilio": "^5.7.2",
    "uuid": "^11.1.0",
    "zod": "^3.25.71"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/google.maps": "^3.58.1",
    "@types/node": "^20.19.7",
    "@types/nodemailer": "^6.4.7",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "chalk": "^5.5.0",
    "depcheck": "^1.4.7",
    "eslint": "^9",
    "eslint-config-next": "15.3.4",
    "eslint-plugin-unused-imports": "^4.1.4",
    "glob": "^11.0.3",
    "jsdom": "^26.1.0",
    "msw": "^2.10.4",
    "ts-prune": "^0.10.3",
    "ts-unused-exports": "^11.0.1",
    "typescript": "^5",
    "unimported": "^1.31.0",
    "vitest": "^3.2.4"
  }
}
