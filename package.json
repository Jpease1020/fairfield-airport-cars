{
  "name": "fairfield-airport-cars",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "dev:ip": "next dev -H 0.0.0.0",
    "tunnel": "./scripts/tunnel.sh",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint src --config eslint.config.js",
    "lint:fix": "eslint src --config eslint.config.js --fix",
    "type-check": "tsc --noEmit",
    "test": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:unit": "TZ=America/New_York vitest run tests/unit --coverage",
    "test:integration": "TZ=America/New_York vitest run tests/integration --coverage",
    "test:e2e": "npm run test:e2e:ui-mocked && npm run test:e2e:preview-safe",
    "test:e2e:ui-mocked": "playwright test --config config/playwright.ui-mocked.config.ts",
    "test:e2e:preview-safe": "playwright test --config config/playwright.preview-safe.config.ts",
    "test:e2e:full-flow": "playwright test --config config/playwright.full-flow.config.ts",
    "test:e2e:ci": "E2E_CI=1 npm run test:e2e:preview-safe",
    "test:e2e:local": "playwright test --config config/playwright.full-flow.config.ts",
    "test:e2e:critical": "playwright test --config config/playwright.preview-safe.config.ts tests/e2e/preview-safe/location-input-autocomplete.spec.ts --project=chromium",
    "test:api": "vitest run tests/api --coverage",
    "test:booking-submit": "BASE_URL=http://localhost:3000 playwright test --config config/playwright.full-flow.config.ts --project=chromium tests/e2e/full-flow/service-area-validation.spec.ts",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:api && npm run test:e2e",
    "firebase:emulators": "firebase emulators:start",
    "firebase:emulators:seed": "node scripts/seed-cms-to-emulators.js",
    "deploy": "npm run build && vercel --prod",
    "deploy:preview": "npm run build && vercel",
    "cms:export-snapshot": "node scripts/export-cms-snapshot.mjs",
    "cms:verify-parity": "node scripts/verify-cms-static-parity.mjs",
    "sms:backfill-threads": "node scripts/backfill-sms-thread-ids.mjs",
    "smoke:prod": "node scripts/smoke-test-production.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@googlemaps/google-maps-services-js": "^3.4.1",
    "@hookform/resolvers": "^5.4.0",
    "@types/styled-components": "^5.1.36",
    "@vercel/analytics": "^2.0.1",
    "@vis.gl/react-google-maps": "^1.8.3",
    "autoprefixer": "^10.5.0",
    "dompurify": "^3.4.10",
    "dotenv": "^17.4.2",
    "firebase": "^12.14.0",
    "firebase-admin": "^13.10.0",
    "google-auth-library": "^10.7.0",
    "googleapis": "^173.0.0",
    "ics": "^3.12.0",
    "lucide-react": "^1.18.0",
    "next": "^16.2.9",
    "nodemailer": "^8.0.11",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.78.0",
    "square": "^44.1.0",
    "styled-components": "^6.4.2",
    "twilio": "^6.0.2",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/google.maps": "^3.65.1",
    "@types/node": "^25.9.3",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "chalk": "^5.6.2",
    "depcheck": "^1.4.7",
    "eslint": "^10.4.1",
    "eslint-config-next": "^16.2.9",
    "eslint-plugin-unused-imports": "^4.4.1",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "ts-prune": "^0.10.3",
    "ts-unused-exports": "^11.0.1",
    "typescript": "^6.0.3",
    "unimported": "^1.31.0",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "googleapis-common": {
      "google-auth-library": "10.7.0"
    },
    "google-gax": {
      "google-auth-library": "10.7.0"
    }
  }
}
