rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Special seeding rules for emulator development
    // These allow the seeding script to create test data
    match /drivers/{driverId} {
      allow read, write: if request.auth != null;  // Allow if authenticated
    }

    match /users/{userId} {
      allow read, write: if request.auth != null;  // Allow if authenticated for seeding
    }

    match /payments/{paymentId} {
      allow read, write: if request.auth != null;  // Allow if authenticated
    }

    // Allow public read access to CMS configuration
    match /cms/{document} {
      allow read: if true;
      allow write: if true;  // Temporarily allow writes for development
    }

    // Allow public booking creation for customer bookings
    match /bookings/{bookingId} {
      allow create: if true;  // Allow public booking creation
      allow read, write: if request.auth != null;  // Admin operations require auth
    }

    // Allow admin access to feedback collection
    match /feedback/{feedbackId} {
      allow read, write: if request.auth != null;  // Admin operations require auth
    }

    // Allow reads and writes to the comments collection
    match /comments/{commentId} {
      allow read, write: if true;
    }

    // Deny all other reads and writes by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
