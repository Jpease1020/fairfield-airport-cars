{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/design/*": [
        "./src/design/*"
      ],
      "@/ui": [
        "./src/design/ui"
      ],
      "@/components/*": [
        "./src/design/components/*"
      ],
      "@/components/ui": [
        "./src/design/components/core/layout"
      ],
      "@/components/ui/*": [
        "./src/design/components/core/layout/*"
      ],
      "@/components/layout": [
        "./src/design/components/core/layout"
      ],
      "@/components/layout/*": [
        "./src/design/components/core/layout/*"
      ],
      "@/components/admin/*": [
        "./src/design/components/business/admin/*"
      ],
      "@/components/business/*": [
        "./src/components/business/*"
      ],
      "@/components/booking/*": [
        "./src/components/booking/*"
      ],
      "@/components/home/*": [
        "./src/components/home/*"
      ],
      "@/components/app": [
        "./src/components/app"
      ],
      "@/components/app/*": [
        "./src/components/app/*"
      ],
      "@/components/marketing/*": [
        "./src/design/components/business/marketing/*"
      ],
      "@/components/icons/*": [
        "./src/design/components/icons/*"
      ],
      "@/components/calendar/*": [
        "./src/components/calendar/*"
      ],
      "@/components/pwa/*": [
        "./src/components/pwa/*"
      ],
      "@/components/providers/*": [
        "./src/design/providers/*"
      ],
      "@/ui/*": [
        "./src/design/components/core/layout/*"
      ],
      "@/icons/*": [
        "./src/design/components/icons/*"
      ],
      "@/business/*": [
        "./src/design/components/business/*"
      ],
      "@/providers/*": [
        "./src/providers/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "temp-design-library",
    "temp"
  ]
}
