#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

#
# Pre-push hook to run tests before allowing a push
# Runs: unit tests, integration tests, build, and critical E2E tests (if server available)
#

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo "${BLUE}🧪 Running pre-push tests...${NC}"

# Check if npm is available
if ! command -v npm >/dev/null 2>&1; then
    echo "${RED}❌ npm is not available. Please install Node.js and npm.${NC}"
    exit 1
fi

# Run unit tests
echo "${YELLOW}🔬 Running unit tests...${NC}"
UNIT_OUTPUT=$(npm run test:unit 2>&1)
UNIT_EXIT_CODE=$?

if [ $UNIT_EXIT_CODE -eq 0 ]; then
    echo "${GREEN}✅ Unit tests passed!${NC}"
else
    echo "${RED}❌ Unit tests failed!${NC}"
    echo "$UNIT_OUTPUT"
    echo ""
    echo "${YELLOW}💡 Please fix failing unit tests before pushing.${NC}"
    exit 1
fi

# Run integration tests
echo "${YELLOW}🔗 Running integration tests...${NC}"
INTEGRATION_OUTPUT=$(npm run test:integration 2>&1)
INTEGRATION_EXIT_CODE=$?

if [ $INTEGRATION_EXIT_CODE -eq 0 ]; then
    echo "${GREEN}✅ Integration tests passed!${NC}"
else
    echo "${RED}❌ Integration tests failed!${NC}"
    echo "$INTEGRATION_OUTPUT"
    echo ""
    echo "${YELLOW}💡 Please fix failing integration tests before pushing.${NC}"
    exit 1
fi

# Run build to ensure code compiles
echo "${YELLOW}🏗️  Running build...${NC}"
BUILD_OUTPUT=$(npm run build 2>&1)
BUILD_EXIT_CODE=$?

if [ $BUILD_EXIT_CODE -eq 0 ]; then
    echo "${GREEN}✅ Build passed!${NC}"
else
    echo "${RED}❌ Build failed!${NC}"
    echo "$BUILD_OUTPUT"
    echo ""
    echo "${YELLOW}💡 Please fix build errors before pushing.${NC}"
    exit 1
fi

# Check if dev server is running on port 3000 for E2E tests
echo "${YELLOW}🌐 Checking for dev server...${NC}"
if curl -s http://localhost:3000 > /dev/null 2>&1; then
    echo "${YELLOW}🎭 Dev server detected! Running critical E2E tests...${NC}"
    E2E_OUTPUT=$(npm run test:e2e:critical 2>&1)
    E2E_EXIT_CODE=$?

    if [ $E2E_EXIT_CODE -eq 0 ]; then
        echo "${GREEN}✅ Critical E2E tests passed!${NC}"
    else
        echo "${RED}❌ Critical E2E tests failed!${NC}"
        echo "$E2E_OUTPUT"
        echo ""
        echo "${YELLOW}💡 The autocomplete or booking form may be broken.${NC}"
        echo "${YELLOW}💡 Please fix E2E test failures before pushing.${NC}"
        exit 1
    fi
else
    echo "${YELLOW}⚠️  No dev server running on localhost:3000${NC}"
    echo "${YELLOW}   Skipping E2E tests. Run 'npm run dev' to enable E2E testing.${NC}"
    echo "${YELLOW}   RECOMMENDATION: Run E2E tests manually before deploying critical changes.${NC}"
fi

echo "${GREEN}🎉 All tests and build passed! Proceeding with push...${NC}"
exit 0
