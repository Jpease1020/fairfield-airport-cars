#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

#
# Pre-push hook to run unit and integration tests
# This hook will run tests before allowing a push

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo "${BLUE}🧪 Running pre-push tests...${NC}"

# Check if npm is available
if ! command -v npm >/dev/null 2>&1; then
    echo "${RED}❌ npm is not available. Please install Node.js and npm.${NC}"
    exit 1
fi

# Run unit tests
echo "${YELLOW}🔬 Running unit tests...${NC}"
UNIT_OUTPUT=$(npm run test:unit 2>&1)
UNIT_EXIT_CODE=$?

if [ $UNIT_EXIT_CODE -eq 0 ]; then
    echo "${GREEN}✅ Unit tests passed!${NC}"
else
    echo "${RED}❌ Unit tests failed!${NC}"
    echo "$UNIT_OUTPUT"
    echo ""
    echo "${YELLOW}💡 Please fix failing unit tests before pushing.${NC}"
    exit 1
fi

# Run integration tests
echo "${YELLOW}🔗 Running integration tests...${NC}"
INTEGRATION_OUTPUT=$(npm run test:integration 2>&1)
INTEGRATION_EXIT_CODE=$?

if [ $INTEGRATION_EXIT_CODE -eq 0 ]; then
    echo "${GREEN}✅ Integration tests passed!${NC}"
else
    echo "${RED}❌ Integration tests failed!${NC}"
    echo "$INTEGRATION_OUTPUT"
    echo ""
    echo "${YELLOW}💡 Please fix failing integration tests before pushing.${NC}"
    exit 1
fi

echo "${GREEN}🎉 All tests passed! Proceeding with push...${NC}"
exit 0

