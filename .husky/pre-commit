#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

#
# Pre-commit hook to lint staged files
# This hook will run ESLint on all staged files before allowing a commit

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo "${BLUE}🔍 Running pre-commit checks...${NC}"

# Check if we're in a git repository
if ! git rev-parse --verify HEAD >/dev/null 2>&1; then
    echo "${YELLOW}⚠️  Initial commit - skipping linting${NC}"
    exit 0
fi

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx)$' | grep -v 'node_modules' | grep -v '\.d\.ts$' | grep -v '\.min\.js$')

if [ -z "$STAGED_FILES" ]; then
    echo "${GREEN}✅ No TypeScript/JavaScript files to lint${NC}"
    exit 0
fi

echo "${YELLOW}📝 Files to lint:${NC}"
echo "$STAGED_FILES" | sed 's/^/  - /'

# Check if ESLint is available
if ! command -v npx >/dev/null 2>&1; then
    echo "${RED}❌ npx is not available. Please install Node.js and npm.${NC}"
    exit 1
fi

# Run ESLint on staged files (only fail on errors, not warnings)
echo "${YELLOW}🔧 Running ESLint...${NC}"
ESLINT_OUTPUT=$(npx eslint $STAGED_FILES --quiet 2>&1)
ESLINT_EXIT_CODE=$?

if [ $ESLINT_EXIT_CODE -eq 0 ]; then
    echo "${GREEN}✅ ESLint passed!${NC}"
else
    echo "${RED}❌ ESLint failed!${NC}"
    echo "$ESLINT_OUTPUT"
    echo ""
    echo "${YELLOW}💡 You can run 'npm run lint:fix' to automatically fix some issues.${NC}"
    echo "${YELLOW}💡 Or run 'npx eslint <filename>' to lint a specific file.${NC}"
    exit 1
fi

# Run TypeScript type checking
echo "${YELLOW}🔍 Running TypeScript type check...${NC}"
TSC_OUTPUT=$(npm run type-check 2>&1)
TSC_EXIT_CODE=$?

if [ $TSC_EXIT_CODE -eq 0 ]; then
    echo "${GREEN}✅ TypeScript type check passed!${NC}"
else
    echo "${RED}❌ TypeScript type check failed!${NC}"
    echo "$TSC_OUTPUT"
    echo ""
    echo "${YELLOW}💡 Please fix the type errors before committing.${NC}"
    exit 1
fi

echo "${GREEN}🎉 All checks passed! Proceeding with commit...${NC}"
exit 0
